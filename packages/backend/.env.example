# BioLab LABSYNC Backend Configuration
# Copy this file to .env and adjust values

SECRET_KEY=change-me-in-production-use-a-strong-random-key
DATABASE_URL=sqlite+aiosqlite:///./labsync.db
ASYNC_DATABASE_URL=sqlite+aiosqlite:///./labsync.db

# PostgreSQL (optional - for production)
# DATABASE_URL=postgresql+asyncpg://biolab:your_password@localhost:5432/biolab
# ASYNC_DATABASE_URL=postgresql+asyncpg://biolab:your_password@localhost:5432/biolab

DEBUG=true
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
REDIS_URL=redis://localhost:6379/0
SYNC_SERVER_PORT=8000
